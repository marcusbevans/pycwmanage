# ConnectWise API Configuration
# Copy this file to .env and fill in your actual values

# ConnectWise site URL (e.g., na.myconnectwise.net)
CW_API_URL=your.connectwise.net
CW_SITE=your.connectwise.net

# Your ConnectWise company identifier
CW_COMPANY_ID=your_company_id

# API Keys - Generate these in ConnectWise under System > Members > API Members
CW_PUBLIC_KEY=your_public_key_here
CW_PRIVATE_KEY=your_private_key_here

# Client ID for your integration
CW_CLIENT_ID=your_client_id_here